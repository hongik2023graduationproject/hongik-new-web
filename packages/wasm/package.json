{
  "name": "@hongik/wasm",
  "version": "1.0.0",
  "description": "Hong-ik WASM bindings for browser execution",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "public"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc && tsc -p tsconfig.worker.json",
    "test": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hongik/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
