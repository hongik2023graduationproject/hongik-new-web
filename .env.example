# hongik-web 환경 변수 예시
# apps/playground (Next.js) 기준. 변수는 NEXT_PUBLIC_ 접두사가 있으면 클라이언트 번들에 포함된다는 점에 유의.

# ────────────────────────────────────
# API 엔드포인트 (Required)
# ────────────────────────────────────

# 백엔드 API 베이스 URL. Header.tsx의 executeViaAPI / shareCode가 사용.
# 클라이언트가 직접 요청하므로 NEXT_PUBLIC_ 필요.
NEXT_PUBLIC_API_BASE_URL=https://api.hong-ik.dev

# ────────────────────────────────────
# 빌드 설정
# ────────────────────────────────────

# Next.js 환경. production 빌드 시 dev 도구 비활성, source map 처리 변경.
NODE_ENV=production

# ────────────────────────────────────
# 관측 (선택 — TBD)
# ────────────────────────────────────

# Sentry 통합 아직 미구현. env var만 예약.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=     # source map 업로드용, 서버 전용
